{
 "id": "resistor.voltage_drop",
 "domain": "electromagnetism",
 "description": "Voltage across a resistor (Ohm's law), V = I R.",
 "inputs": [
  {
   "name": "I",
   "dimension": "current"
  },
  {
   "name": "R",
   "dimension": "resistance"
  }
 ],
 "method": {
  "kind": "formula",
  "expr": "I * R"
 },
 "output": {
